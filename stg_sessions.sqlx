config {
  type: "table",
  schema: "staging",
  assertions: {
    nonNull: ["session_id"],
    rowConditions: ["duration_seconds >= 0"]
  }
}

SELECT
  CAST(session_id AS INT64)               AS session_id,
  NULLIF(CAST(customer_id AS STRING), '') AS customer_id,
  page_visited,
  CAST(duration_seconds AS INT64)         AS duration_seconds,
  LOWER(device)                           AS device,
  DATE(session_date)                      AS session_date
FROM ${ref("raw_sessions")}
